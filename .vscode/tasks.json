{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "kde-builder",
            "args": [
                "--no-src",
                "--no-include-dependencies",
                "--debug",
                "lokalize"
            ]
        },
        {
            "label": "Rebuild",
            "type": "shell",
            "command": "kde-builder",
            "args": [
                "--debug",
                "lokalize"
            ]
        },
        {
            "label": "Clean and rebuild",
            "type": "shell",
            "command": "kde-builder",
            "args": [
                "--refresh-build",
                "--debug",
                "lokalize"
            ]
        },
        {
            "label": "Run",
            "type": "shell",
            "command": "kde-builder",
            "args": [
                "--run",
                "lokalize"
            ]
        },
        {
            "label": "Build and run",
            "type": "shell",
            "command": "kde-builder",
            "args": [
                "--run",
                "lokalize"
            ],
            "dependsOn": [
                "Build"
            ]
        },
        {
            "label": "Run non-Appium tests",
            "type": "shell",
            "command": "kde-builder",
            "args": [
                "--debug",
                "--run-tests",
                "lokalize",
                "--no-include-dependencies",
                "--no-src"
            ]
        },
        {
            "label": "Run all tests, including Appium ones",
            "type": "shell",
            "command": "kde-builder",
            "args": [
                "--debug",
                "--run-tests",
                "lokalize",
                "--no-include-dependencies",
                "--no-src",
                "--cmake-options='-DBUILD_APPIUM_TESTS=ON'"
            ]
        }
    ]
}
